# ============================================================
# AfterHours — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored — never commit real keys.
#
# In GitHub Actions, add these as repository Secrets under:
# Settings → Secrets and variables → Actions → New repository secret
# ============================================================

# Google Maps JavaScript API Key
# Enable in Google Cloud Console: Maps JavaScript API + Directions API
# Restrict to HTTP referrers (your deployed domain) to prevent abuse
VITE_GOOGLE_MAPS_KEY=

# Google Maps Map ID (optional — for custom cloud-based dark styling)
# Create at: console.cloud.google.com → Google Maps Platform → Map Styles
VITE_GOOGLE_MAP_ID=

# TfL Open Data API Key
# Register free at: https://api-portal.tfl.gov.uk
# Without a key the app still works but at reduced rate limits
VITE_TFL_APP_KEY=
